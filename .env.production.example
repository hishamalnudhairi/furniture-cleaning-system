# ==========================================================
# قالب إعدادات الإنتاج (Hostinger) — انسخه إلى .env على السيرفر
# لا تضع بيانات حقيقية في هذا الملف، ولا ترفع .env إلى Git.
# ==========================================================

APP_NAME="Furniture Cleaning System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

# اللغة والمنطقة الزمنية
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA
APP_TIMEZONE=Asia/Muscat

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# السجلّات — في الإنتاج يُفضّل مستوى أقل تفصيلًا
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ===== قاعدة بيانات MySQL على Hostinger =====
# احصل على هذه القيم من hPanel → Databases بعد إنشاء قاعدة البيانات
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# الجلسات والكاش والطوابير (database مناسبة لاستضافة مشتركة بلا Redis)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# اضبط النطاق على دومينك لتعمل الكوكيز بشكل صحيح (مثال: .your-domain.com)
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# مهم: رفع الشعار/البوستر/الصور يعتمد على قرص public
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

# البريد — اضبطه لاحقًا إذا احتجت إرسال بريد فعلي (غير مطلوب للنظام حاليًا)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
